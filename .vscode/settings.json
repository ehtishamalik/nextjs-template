{
  // Set Prettier as the default formatter for TypeScript and TSX files
  "editor.defaultFormatter": "biomejs.biome",

  // Enable format on save
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit"
  }

  // Enable Prettier for specific languages
  // "[typescript]": {
  //   "editor.defaultFormatter": "biomejs.biome"
  // },

  // "[javascript]": {
  //   "editor.defaultFormatter": "biomejs.biome"
  // },

  // "[typescriptreact]": {
  //   "editor.defaultFormatter": "biomejs.biome"
  // },

  // "[css]": {
  //   "editor.defaultFormatter": "biomejs.biome"
  // }
}
